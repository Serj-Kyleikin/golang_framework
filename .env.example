## ENV ##
ENV=production

## App base path ##
WORKDIR=/app

## GATEWAY ##
GATEWAY_EXT_PORT=8443
GATEWAY_INT_PORT=8443

## Backends (internal container ports) ##
BACKEND1_APP_PORT=8101
BACKEND2_APP_PORT=8102

## API Backends ##
API_BACKEND_1=http://backend1:${BACKEND1_APP_PORT}
API_BACKEND_2=http://backend2:${BACKEND2_APP_PORT}

##  DB descriptors ##
DB_EXT_PORT=5432
DB_INT_PORT=5432
DB_HOST=db
DB_USER=go_user
DB_PASS=go_pass
DB_NAME=go_db
DB_SSLMODE=disable

## Convenience DSN ##
DB_URL=postgres://${DB_USER}:${DB_PASS}@${DB_HOST}:${DB_INT_PORT}/${DB_NAME}?sslmode=${DB_SSLMODE}

## pgAdmin ##
PGADMIN_EXT_PORT=8081
PGADMIN_DEFAULT_EMAIL=admin@local.ru
PGADMIN_DEFAULT_PASSWORD=admin

## TLS certs (host) ##
CERTS_HOST_PATH=./Infrastructure/certs
CERTS_DIR=certs
CERT_NAME=cert.pem
CERT_KEY=key.pem

## Migrations path (relative to project root) ##
MIGRATIONS_DIR=Backend/db/migrations

## Swagger ##
SWAGGER_EXT_PORT=8082